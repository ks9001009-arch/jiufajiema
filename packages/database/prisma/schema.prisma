generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  DISABLED
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model Company {
  id        String        @id @default(uuid())
  name      String
  code      String        @unique
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  teams     Team[]
  users     User[]
  auditLogs AuditLog[]

  services       Service[]
  providers      Provider[]
  phoneResources PhoneResource[]
  orders         Order[]
}

model Team {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model Role {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String
  displayName  String?
  status       UserStatus @default(ACTIVE)
  companyId    String?
  company      Company?   @relation(fields: [companyId], references: [id])
  teamId       String?
  team         Team?      @relation(fields: [teamId], references: [id])
  roleId       String?
  role         Role?      @relation(fields: [roleId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs AuditLog[]
  orders    Order[]
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id])
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  action      String
  targetType  String?
  targetId    String?
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

enum ServiceStatus {
  ACTIVE
  DISABLED
}

enum ProviderStatus {
  ACTIVE
  DISABLED
}

model PhoneResource {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])

  phone String

  country String?

  status PhoneStatus @default(AVAILABLE)

  cost Decimal @db.Decimal(10, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([status])
  @@index([providerId])
}

enum PhoneStatus {
  AVAILABLE
  LOCKED
  USED
  EXPIRED
  DISABLED
}

enum OrderStatus {
  PENDING
  WAIT_SMS
  SUCCESS
  FAILED
  CANCELLED
}

enum SmsStatus {
  RECEIVED
  FAILED
}

model Service {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String
  code String

  description String?

  status ServiceStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providers Provider[]
  orders    Order[]

  @@unique([companyId, code])
}

model Provider {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String
  code String

  adapter String

  config Json?

  status ProviderStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services       Service[]
  phoneResources PhoneResource[]
  orders         Order[]

  @@unique([companyId, code])
}

model Order {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])

  phoneResourceId String
  phoneResource   PhoneResource @relation(fields: [phoneResourceId], references: [id])

  status OrderStatus @default(PENDING)

  amount Decimal @db.Decimal(10, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sms Sms[]
}

model Sms {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  code String?

  content String?

  status SmsStatus @default(RECEIVED)

  receivedAt DateTime?

  createdAt DateTime @default(now())

  @@index([orderId])
}
