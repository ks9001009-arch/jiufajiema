generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  DISABLED
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model Company {
  id        String        @id @default(uuid())
  name      String
  code      String        @unique
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  teams     Team[]
  users     User[]
  auditLogs AuditLog[]

  services       Service[]
  providers      Provider[]
  phoneResources PhoneResource[]
  orders         Order[]
  countries      CompanyCountry[]
  walletAccounts WalletAccount[]
  walletTransactions WalletTransaction[]
}

model Team {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  countryPolicyMode TeamCountryPolicyMode @default(INHERIT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  countryPolicies TeamCountry[]
  orders          Order[]
}

model Role {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String
  displayName  String?
  status       UserStatus @default(ACTIVE)
  companyId    String?
  company      Company?   @relation(fields: [companyId], references: [id])
  teamId       String?
  team         Team?      @relation(fields: [teamId], references: [id])
  roleId       String?
  role         Role?      @relation(fields: [roleId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs AuditLog[]
  orders    Order[]
  walletAccounts          WalletAccount[]     @relation("WalletAccountOwner")
  actedWalletTransactions WalletTransaction[] @relation("WalletTransactionActor")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id])
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  action      String
  targetType  String?
  targetId    String?
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

enum ServiceStatus {
  ACTIVE
  DISABLED
}

enum ProviderStatus {
  ACTIVE
  DISABLED
}

model PhoneResource {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])

  phone String

  country String?

  status PhoneStatus @default(AVAILABLE)

  cost Decimal @db.Decimal(10, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@unique([companyId, phone])
  @@index([companyId])
  @@index([providerId])
  @@index([status])
}

enum PhoneStatus {
  AVAILABLE
  LOCKED
  USED
  EXPIRED
  DISABLED
}

enum OrderStatus {
  PENDING
  WAIT_SMS
  SUCCESS
  FAILED
  CANCELLED
}

enum SmsStatus {
  RECEIVED
  FAILED
}

enum TeamCountryPolicyMode {
  INHERIT
  ALLOW_LIST
}

model Country {
  code      String  @id
  nameZh    String
  nameEn    String
  emoji     String?
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)

  companyCountries CompanyCountry[]
  teamCountries    TeamCountry[]
}

model CompanyCountry {
  companyId   String
  countryCode String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  country     Country @relation(fields: [countryCode], references: [code], onDelete: Restrict)

  @@id([companyId, countryCode])
  @@index([companyId])
}

model TeamCountry {
  teamId      String
  countryCode String
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  country     Country @relation(fields: [countryCode], references: [code], onDelete: Restrict)

  @@id([teamId, countryCode])
  @@index([teamId])
}

model Service {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String
  code String

  description String?

  status ServiceStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providers Provider[]
  orders    Order[]

  @@unique([companyId, code])
}

model Provider {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name String
  code String

  adapter String

  config Json?

  status ProviderStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services       Service[]
  phoneResources PhoneResource[]
  orders         Order[]

  @@unique([companyId, code])
}

model Order {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])

  phoneResourceId String
  phoneResource   PhoneResource @relation(fields: [phoneResourceId], references: [id])

  status OrderStatus @default(PENDING)

  amount Decimal @db.Decimal(10, 4)

  expiresAt    DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sms Sms[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([userId])
  @@index([teamId])
  @@index([phoneResourceId])
  @@index([createdAt])
  @@index([status, expiresAt])
}

model Sms {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  code String?

  content String?

  status SmsStatus @default(RECEIVED)

  receivedAt DateTime?

  createdAt DateTime @default(now())

  @@index([orderId])
}

enum WalletAccountStatus {
  ACTIVE
  DISABLED
}

enum WalletTransactionType {
  RECHARGE
  MANUAL_CREDIT
  MANUAL_DEBIT
  FREEZE
  RELEASE
  CAPTURE
  REFUND
}

model WalletAccount {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String?
  user   User?   @relation("WalletAccountOwner", fields: [userId], references: [id])

  currency String

  availableBalance Decimal @default(0) @db.Decimal(18, 4)
  frozenBalance    Decimal @default(0) @db.Decimal(18, 4)

  status WalletAccountStatus @default(ACTIVE)

  version Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]

  @@index([companyId])
  @@index([userId])
}

model WalletTransaction {
  id String @id @default(uuid())

  walletAccountId String
  walletAccount   WalletAccount @relation(fields: [walletAccountId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  type WalletTransactionType

  amount Decimal @db.Decimal(18, 4)

  availableBefore Decimal @db.Decimal(18, 4)
  availableAfter  Decimal @db.Decimal(18, 4)
  frozenBefore    Decimal @db.Decimal(18, 4)
  frozenAfter     Decimal @db.Decimal(18, 4)

  referenceType String?
  referenceId   String?

  idempotencyKey String @unique

  actorUserId String?
  actorUser   User?   @relation("WalletTransactionActor", fields: [actorUserId], references: [id])

  remark String?

  createdAt DateTime @default(now())

  @@index([walletAccountId, createdAt])
  @@index([companyId, createdAt])
  @@index([referenceType, referenceId])
}
