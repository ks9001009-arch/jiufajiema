{
  "name": "jiufa-jiema-platform",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "echo \"Please run pnpm dev:api and pnpm dev:web in separate terminals\"",
    "dev:api": "pnpm --dir apps/api run start:dev",
    "dev:web": "pnpm --dir apps/web run dev -- --host 0.0.0.0",
